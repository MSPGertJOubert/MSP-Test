#include <WiFi.h>
#include <WebSocketsClient.h>
#include <ArduinoJson.h>
#include <Wire.h>

// =========================
// WiFi & Railway Config
// =========================
const char* homeSSID     = "ssid";
const char* homePassword = "password";
const char* wsHost = "";
const int   wsPort = 443;
const char* wsPath = "/";

WebSocketsClient railwayWS;

// =========================
// Pins & Settings
// =========================
const int SCL_PIN  = 5; // Connected to "C"
const int SDA_PIN  = 6; // Connected to "D"
const int HALL_PIN = 4;
const int LED_PIN  = 8; 

uint8_t LIS_ADDR = 0x18; 

// Detection Sensitivity
const float ACCEL_THRESHOLD = 300.0; 
const int   HALL_THRESHOLD  = 200;   // Change in analog value to trigger
unsigned long lastTrigger = 0;
const unsigned long COOLDOWN = 3000;

float accelBaseline = 1000.0;
int   hallBaseline  = 0;

// =========================
// Direct I2C Functions
// =========================
void writeRegister(uint8_t reg, uint8_t val) {
  Wire.beginTransmission(LIS_ADDR);
  Wire.write(reg);
  Wire.write(val);
  Wire.endTransmission();
}

int16_t readAxis(uint8_t reg) {
  Wire.beginTransmission(LIS_ADDR);
  Wire.write(reg);
  Wire.endTransmission(false);
  Wire.requestFrom(LIS_ADDR, (uint8_t)2);
  if (Wire.available() == 2) {
    uint8_t lsb = Wire.read();
    uint8_t msb = Wire.read();
    return (int16_t)((msb << 8) | lsb);
  }
  return 0;
}

// =========================
// Helpers
// =========================
void flashLED(int times, int ms) {
  for (int i = 0; i < times; i++) {
    digitalWrite(LED_PIN, LOW); delay(ms);
    digitalWrite(LED_PIN, HIGH); delay(ms);
  }
}

void sendAlert(String sensorType, float delta) {
  StaticJsonDocument<256> doc;
  doc["movement"] = true;
  doc["source"] = "Zone A";
  doc["sensor"] = sensorType;
  doc["delta"] = (int)delta;
  
  String json;
  serializeJson(doc, json);
  railwayWS.sendTXT(json);
  Serial.println("Alert Sent: " + json);
}

void onRailwayEvent(WStype_t type, uint8_t* payload, size_t length) {
  if(type == WStype_CONNECTED) Serial.println(">> WebSocket Connected!");
}

// =========================
// Setup
// =========================
void setup() {
  Serial.begin(115200);
  delay(1000);
  
  pinMode(LED_PIN, OUTPUT);
  digitalWrite(LED_PIN, HIGH); 

  // Initialize I2C
  Wire.begin(SDA_PIN, SCL_PIN);
  delay(100);

  // Auto-Detect Accel Address
  Wire.beginTransmission(0x18);
  if (Wire.endTransmission() != 0) { LIS_ADDR = 0x19; } 
  else { LIS_ADDR = 0x18; }

  // Initialize Accel: 100Hz mode
  writeRegister(0x20, 0x50); 
  
  WiFi.begin(homeSSID, homePassword);
  while (WiFi.status() != WL_CONNECTED) { delay(500); Serial.print("."); }

  // Calibration
  Serial.println("\nCALIBRATING... KEEP STILL.");
  float aSum = 0;
  long hSum = 0;
  for(int i = 0; i < 50; i++) {
    float x = readAxis(0x28) * 0.061;
    float y = readAxis(0x2A) * 0.061;
    float z = readAxis(0x2C) * 0.061;
    aSum += sqrt(x*x + y*y + z*z);
    hSum += analogRead(HALL_PIN);
    delay(20);
  }
  accelBaseline = aSum / 50.0;
  hallBaseline  = hSum / 50;
  
  railwayWS.beginSSL(wsHost, wsPort, wsPath);
  railwayWS.onEvent(onRailwayEvent);
  Serial.println("SYSTEM READY.");
}

// =========================
// Loop
// =========================
void loop() {
  railwayWS.loop();

  unsigned long now = millis();

  // 1. Check Accelerometer
  float x = readAxis(0x28) * 0.061;
  float y = readAxis(0x2A) * 0.061;
  float z = readAxis(0x2C) * 0.061;
  float magnitude = sqrt(x*x + y*y + z*z);
  float aDelta = abs(magnitude - accelBaseline);

  if (aDelta > ACCEL_THRESHOLD && (now - lastTrigger > COOLDOWN)) {
    Serial.print("ACCEL MOTION! Delta: "); Serial.println(aDelta);
    flashLED(2, 80);
    sendAlert("Accelerometer", aDelta);
    lastTrigger = now;
  }

  // 2. Check Hall Effect Sensor
  int currentHall = analogRead(HALL_PIN);
  int hDelta = abs(currentHall - hallBaseline);

  if (hDelta > HALL_THRESHOLD && (now - lastTrigger > COOLDOWN)) {
    Serial.print("MAGNET DETECTED! Delta: "); Serial.println(hDelta);
    flashLED(4, 40); // Faster flashes for magnet
    sendAlert("HallEffect", (float)hDelta);
    lastTrigger = now;
  }

  delay(30);
}
