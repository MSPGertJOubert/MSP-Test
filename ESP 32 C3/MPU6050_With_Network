#include <Adafruit_MPU6050.h>
#include <Adafruit_Sensor.h>
#include <Wire.h>
#include <WiFi.h>
#include <WebSocketsClient.h>
#include <ArduinoJson.h>

// =========================
// S2 MINI HOTSPOT
// =========================
const char* ssid     = "";
const char* password = "";
const char* wsHost   = "";
const int   wsPort   = 81;
const char* wsPath   = "/";

// =========================
// PIN DEFINITIONS
// =========================
const int SDA_PIN = 5;
const int SCL_PIN = 4;
const int LED_PIN = 8;

// =========================
// MOTION SETTINGS
// =========================
const float THRESHOLD   = 2.5;
const int   ALERT_COOLDOWN = 2000; // ms between alerts to avoid spam

Adafruit_MPU6050 mpu;
WebSocketsClient ws;

unsigned long lastAlertTime = 0;

// =========================
// WEBSOCKET EVENTS
// =========================
void onWSEvent(WStype_t type, uint8_t* payload, size_t length) {
  switch (type) {
    case WStype_CONNECTED:
      Serial.println("Connected to S2 controller!");
      break;
    case WStype_DISCONNECTED:
      Serial.println("Disconnected from S2, retrying...");
      break;
    default:
      break;
  }
}

// =========================
// SEND MOTION ALERT
// =========================
void sendMotionAlert(float motion) {
  StaticJsonDocument<192> doc;
  doc["movement"]   = true;
  doc["delta"]      = motion;
  doc["value"]      = motion;
  doc["source"]     = "Zone A";
  doc["sensor"]     = "accelerometer";
  doc["forwarded"]  = false;
  doc["controller"] = "C3";

  String json;
  serializeJson(doc, json);
  ws.sendTXT(json);

  Serial.print("Alert sent: ");
  Serial.println(json);
}

// =========================
// SETUP
// =========================
void setup() {
  Serial.begin(115200);
  delay(1000);

  pinMode(LED_PIN, OUTPUT);
  digitalWrite(LED_PIN, HIGH); // LED off

  // Init MPU6050
  Wire.begin(SDA_PIN, SCL_PIN);
  if (!mpu.begin()) {
    Serial.println("Failed to find MPU6050 chip");
    while (1) {
      digitalWrite(LED_PIN, LOW);  delay(50);
      digitalWrite(LED_PIN, HIGH); delay(50);
    }
  }
  Serial.println("MPU6050 Found!");

  mpu.setAccelerometerRange(MPU6050_RANGE_8_G);
  mpu.setGyroRange(MPU6050_RANGE_500_DEG);
  mpu.setFilterBandwidth(MPU6050_BAND_21_HZ);

  // Connect to S2 hotspot
  Serial.print("Connecting to S2 hotspot");
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nConnected! IP: " + WiFi.localIP().toString());

  // Connect to local WebSocket server on S2
  ws.begin(wsHost, wsPort, wsPath);
  ws.onEvent(onWSEvent);
  ws.setReconnectInterval(3000);

  Serial.println("Zone A ready");
}

// =========================
// LOOP
// =========================
void loop() {
  ws.loop();

  sensors_event_t a, g, temp;
  mpu.getEvent(&a, &g, &temp);

  float totalAcc = sqrt(
    a.acceleration.x * a.acceleration.x +
    a.acceleration.y * a.acceleration.y +
    a.acceleration.z * a.acceleration.z
  );

  float motion = abs(totalAcc - 9.81);

  if (motion > THRESHOLD) {
    digitalWrite(LED_PIN, LOW); // LED on

    // Only send alert if cooldown has passed
    unsigned long now = millis();
    if (now - lastAlertTime > ALERT_COOLDOWN) {
      Serial.print("Motion detected! Value: ");
      Serial.println(motion);
      sendMotionAlert(motion);
      lastAlertTime = now;
    }

    delay(100);
  } else {
    digitalWrite(LED_PIN, HIGH); // LED off
  }

  delay(10);
}
